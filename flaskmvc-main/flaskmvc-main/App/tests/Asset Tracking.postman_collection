        {
          "name": "Create User",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "let responseData;",
                  "",
                  "pm.test(\"Response body is valid JSON\", function () {",
                  "    responseData = pm.response.json();",
                  "    pm.expect(responseData).to.exist;",
                  "});",
                  "",
                  "const isSuccessStatus = pm.response.code >= 200 && pm.response.code < 300;",
                  "const hasUserPayload = responseData && typeof responseData === 'object' && !Array.isArray(responseData) && responseData.user && typeof responseData.user === 'object';",
                  "const createdUser = hasUserPayload ? responseData.user : null;",
                  "",
                  "pm.test(\"Create user returns success payload for 2xx responses\", function () {",
                  "    if (isSuccessStatus) {",
                  "        pm.expect(responseData).to.be.an('object');",
                  "        pm.expect(responseData.success, 'success flag').to.equal(true);",
                  "        pm.expect(createdUser, 'user payload').to.be.an('object');",
                  "    } else {",
                  "        pm.expect(responseData).to.be.an('object');",
                  "        pm.expect(responseData.success, 'success flag').to.not.equal(true);",
                  "        pm.expect(responseData.message, 'error message').to.be.a('string').and.to.have.lengthOf.at.least(1);",
                  "    }",
                  "});",
                  "",
                  "pm.test(\"Created user fields are valid when user payload exists\", function () {",
                  "    if (!isSuccessStatus || !createdUser) {",
                  "        pm.expect(true).to.equal(true);",
                  "        return;",
                  "    }",
                  "",
                  "    pm.expect(createdUser.user_id, 'user_id').to.be.a('number').and.to.be.at.least(0);",
                  "    pm.expect(createdUser.email, 'email').to.be.a('string').and.to.match(/^[^\\s@]+@[^\\s@]+\\.[^\\s@]+$/);",
                  "    pm.expect(createdUser.username, 'username').to.be.a('string').and.to.have.lengthOf.at.least(1);",
                  "    pm.expect(createdUser.role, 'role').to.be.a('string').and.to.have.lengthOf.at.least(1);",
                  "});",
                  "",
                  "if (isSuccessStatus && createdUser && typeof createdUser.user_id !== 'undefined' && createdUser.user_id !== null) {",
                  "    pm.environment.set('createdUserId', String(createdUser.user_id));",
                  "}"
                ],
