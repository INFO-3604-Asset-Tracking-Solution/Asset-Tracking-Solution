        {
          "name": "Get User List",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "let responseData;",
                  "",
                  "pm.test(\"Response status code is 200\", function () {",
                  "    pm.expect(pm.response.code).to.equal(200);",
                  "});",
                  "",
                  "pm.test(\"Response body is valid JSON\", function () {",
                  "    responseData = pm.response.json();",
                  "    pm.expect(responseData).to.exist;",
                  "});",
                  "",
                  "pm.test(\"Response is a non-empty array\", function () {",
                  "    if (responseData === undefined) {",
                  "        responseData = pm.response.json();",
                  "    }",
                  "",
                  "    pm.expect(responseData).to.be.an('array').that.is.not.empty;",
                  "});",
                  "",
                  "pm.test(\"Response items contain expected user fields and valid types\", function () {",
                  "    if (responseData === undefined) {",
                  "        responseData = pm.response.json();",
                  "    }",
                  "",
                  "    const allowedKeys = ['email', 'role', 'username', 'user_id', 'userId'];",
                  "",
                  "    responseData.forEach(function (user) {",
                  "        pm.expect(user).to.be.an('object');",
                  "        pm.expect(Object.keys(user).length).to.be.greaterThan(0);",
                  "",
                  "        Object.keys(user).forEach(function (key) {",
                  "            pm.expect(allowedKeys).to.include(key);",
                  "        });",
                  "",
                  "        pm.expect(user).to.have.property('email');",
                  "        pm.expect(user.email).to.be.a('string').and.to.have.lengthOf.at.least(1);",
                  "        pm.expect(user.email).to.match(/^[^\\s@]+@[^\\s@]+\\.[^\\s@]+$/, 'Email format is invalid');",
                  "",
                  "        pm.expect(user).to.have.property('role');",
                  "        pm.expect(user.role).to.be.a('string').and.to.have.lengthOf.at.least(1);",
                  "",
                  "        pm.expect(user).to.have.property('username');",
                  "        pm.expect(user.username).to.be.a('string').and.to.have.lengthOf.at.least(1);",
                  "",
                  "        const hasUserId = Object.prototype.hasOwnProperty.call(user, 'user_id');",
                  "        const hasUserIdCamel = Object.prototype.hasOwnProperty.call(user, 'userId');",
                  "",
                  "        if (hasUserId || hasUserIdCamel) {",
                  "            const idValue = hasUserId ? user.user_id : user.userId;",
                  "            pm.expect(idValue).to.be.a('number');",
                  "            pm.expect(idValue % 1).to.equal(0, 'User id should be an integer');",
                  "            pm.expect(idValue).to.be.at.least(0, 'User id should be a non-negative integer');",
                  "        }",
                  "    });",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
